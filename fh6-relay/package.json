{
  "name": "fh6-relay",
  "version": "2.0.1",
  "description": "FH6 telemetry relay — Electron desktop app",
  "author": "GnorpLabs",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.main.json && esbuild src/renderer/main.ts --bundle --platform=browser --outfile=dist/renderer/main.js",
    "start": "npm run build && electron .",
    "test": "jest",
    "pack": "npm run build && electron-builder --win --dir",
    "dist": "npm run build && electron-builder --win"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.4.0",
    "@types/jest": "^29.5.0",
    "esbuild": "^0.21.0"
  },
  "dependencies": {
    "chart.js": "^4.4.0"
  }
}
